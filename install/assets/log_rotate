/var/log/${GEONATURE_APP_NAME}/${GEONATURE_APP_NAME}.log {
    su ${USER} ${USER}
    daily
    rotate 8
    size 100M
    create
    compress
    postrotate
    systemctl reload ${GEONATURE_APP_NAME} || true
    endscript
}
/var/log/${GEONATURE_APP_NAME}/${GEONATURE_APP_NAME}-worker.log {
    su ${USER} ${USER}
    daily
    rotate 8
    size 100M
    create
    compress
    postrotate
    systemctl reload ${GEONATURE_APP_NAME}-worker || true
    endscript
}
